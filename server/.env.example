DATABASE_URL=postgresql://postgres:[my-pass]@db.example.supabase.co:5432/postgres

# ── Groq (used by: Router, Planner, QA nodes) ──────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Ollama Cloud (used by: Executor node — actual code writing) ─────────────
OLLAMA_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_BASE_URL=https://api.ollama.com/v1
OLLAMA_MODEL=devstral